{
    "name": "badr42000/gestiontaches-logs",
    "description": "Application de gestion de tâches avec journalisation syslog et dashboard de supervision",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-sockets": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Shared\\": "src/Shared/",
            "App\\": "app/src/",
            "Dashboard\\": "dashboard/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration phpstan.neon",
        "test": "phpunit"
    }
}
